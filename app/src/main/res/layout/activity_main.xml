<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- MapView zauzima ceo ekran -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Kompaktni Toolbar na vrhu sa transparentnim dugmadima -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@drawable/toolbar_background"
        android:orientation="horizontal"
        android:padding="12dp"
        android:elevation="8dp">

        <!-- Ikona menija -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/button_transparent"
            android:src="@android:drawable/ic_menu_more"
            android:contentDescription="Meni"
            android:padding="8dp" />

        <!-- Tracking Mode dugme -->
        <Button
            android:id="@+id/btnTrackingMode"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Pratim: Samo sebe"
            android:textSize="10sp"
            android:background="@drawable/button_transparent"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"
            android:padding="4dp" />

        <!-- Moja lokacija dugme -->
        <Button
            android:id="@+id/btnMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="📍"
            android:textSize="12sp"
            android:background="@drawable/button_transparent"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"
            android:padding="4dp" />

        <!-- Export dugme -->
        <Button
            android:id="@+id/btnExport"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="📤"
            android:textSize="12sp"
            android:background="@drawable/button_transparent"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"
            android:padding="4dp"
            android:enabled="false" />

        <!-- Reset dugme -->
        <Button
            android:id="@+id/btnReset"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="🔄"
            android:textSize="12sp"
            android:background="@drawable/button_transparent"
            android:textColor="@android:color/white"
            android:padding="4dp"
            android:enabled="false" />

    </LinearLayout>

    <!-- Tracking Panel - dno ekrana -->
    <LinearLayout
        android:id="@+id/trackingPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/panel_background"
        android:orientation="vertical"
        android:padding="12dp"
        android:elevation="8dp">

        <!-- Statistike -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Udaljenost: 0.0 m"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Brzina: 0.0 km/h"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center" />

        </LinearLayout>

        <!-- Kontrolna dugmad - Start/Stop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStartTracking"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="START"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/button_green"
                android:textColor="@android:color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnStopTracking"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="STOP"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/button_gray"
                android:textColor="@android:color/white"
                android:layout_marginStart="6dp"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>

    <!-- Floating Action Button za dodavanje tačaka -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddPoint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_above="@+id/trackingPanel"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Dodaj tačku" />

</RelativeLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- MapView zauzima ceo ekran -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Toolbar na vrhu -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/toolbar_background"
        android:orientation="horizontal"
        android:padding="12dp"
        android:elevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Naslov -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GPS Tracker"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center" />

        <!-- Meni ikonica -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/button_transparent"
            android:src="@drawable/ic_menu_white"
            android:contentDescription="Meni"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Kontrolni panel - DESNA IVICA -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:padding="4dp"
        android:background="@drawable/panel_background"
        android:elevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <!-- Tracking Mode dugme -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnTrackingMode"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_tracking_mode"
            android:contentDescription="Režim praćenja"
            app:fabSize="mini"
            app:tint="@android:color/white" />

        <!-- Moja lokacija dugme -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMyLocation"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_my_location"
            android:contentDescription="Moja lokacija"
            app:fabSize="mini"
            app:tint="@android:color/white" />

        <!-- Google Mape dugme -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnGoogleMaps"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_google_maps"
            android:contentDescription="Google Mape"
            app:fabSize="mini"
            app:tint="@android:color/white" />

        <!-- Sačuvane rute dugme -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSavedRoutes"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_saved_routes"
            android:contentDescription="Sačuvane rute"
            app:fabSize="mini"
            app:tint="@android:color/white" />

        <!-- Export dugme -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnExport"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_export"
            android:contentDescription="Export"
            app:fabSize="mini"
            app:tint="@android:color/white"
            android:enabled="false" />

        <!-- Reset dugme -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnReset"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_reset"
            android:contentDescription="Reset"
            app:fabSize="mini"
            app:tint="@android:color/white"
            android:enabled="false" />

    </LinearLayout>

    <!-- Tracking Panel - dno ekrana -->
    <LinearLayout
        android:id="@+id/trackingPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/panel_background"
        android:orientation="vertical"
        android:padding="12dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Statistike -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Udaljenost: 0.0 m"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Brzina: 0.0 km/h"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center" />

        </LinearLayout>

        <!-- Kontrolna dugmad - Start/Stop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStartTracking"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="START"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/button_green"
                android:textColor="@android:color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnStopTracking"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="STOP"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/button_gray"
                android:textColor="@android:color/white"
                android:layout_marginStart="6dp"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>

    <!-- Floating Action Button za dodavanje tačaka -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddPoint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Dodaj tačku"
        app:layout_constraintBottom_toTopOf="@id/trackingPanel"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>